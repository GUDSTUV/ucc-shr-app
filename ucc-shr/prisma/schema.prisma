generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    Json
  category   String
  coverImage String?
  published  Boolean  @default(false)
  authorId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  User       User     @relation(fields: [authorId], references: [id])
}

model CampaignBanner {
  id        String   @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  venue       String
  startDate   DateTime
  endDate     DateTime?
  capacity    Int?
  published   Boolean   @default(false)
  authorId    String
  createdAt   DateTime  @default(now())
  image       String?
  User        User      @relation(fields: [authorId], references: [id])
  Rsvp        Rsvp[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model Report {
  id          String       @id @default(cuid())
  code        String       @unique
  type        String
  description String
  location    String?
  date        DateTime?
  status      ReportStatus @default(RECEIVED)
  isAnonymous Boolean      @default(true)
  files       String[]
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  Message     Message[]

  @@index([status, createdAt])
  @@index([status, updatedAt])
  @@index([type, createdAt])
}

model Rsvp {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String
  phone     String?
  userType  String
  createdAt DateTime @default(now())
  Event     Event    @relation(fields: [eventId], references: [id])
}

model User {
  id                    String                  @id @default(cuid())
  email                 String                  @unique
  name                  String
  password              String?
  role                  Role                    @default(STAFF)
  createdAt             DateTime                @default(now())
  image                 String?
  emailVerified         Boolean                 @default(false)
  verifyToken           String?                 @unique
  verifyTokenExpiry     DateTime?
  resetToken            String?                 @unique
  resetTokenExpiry      DateTime?
  lastLoginAt           DateTime?
  Article               Article[]
  Event                 Event[]
  Message               Message[]
  NotificationDismissed NotificationDismissed[]
  NotificationRead      NotificationRead[]
  NotificationState     NotificationState[]
  SavedResource         SavedResource[]
  AuditLog              AuditLog[]
}

model NotificationState {
  id         String            @id @default(cuid())
  userId     String
  scope      NotificationScope
  lastSeenAt DateTime?
  clearedAt  DateTime?
  User       User              @relation(fields: [userId], references: [id])

  @@unique([userId, scope])
  @@index([userId])
}

model NotificationRead {
  id             String            @id @default(cuid())
  userId         String
  scope          NotificationScope
  notificationId String
  createdAt      DateTime          @default(now())
  User           User              @relation(fields: [userId], references: [id])

  @@unique([userId, scope, notificationId])
  @@index([userId, scope, createdAt])
}

model NotificationDismissed {
  id             String            @id @default(cuid())
  userId         String
  scope          NotificationScope
  notificationId String
  createdAt      DateTime          @default(now())
  User           User              @relation(fields: [userId], references: [id])

  @@unique([userId, scope, notificationId])
  @@index([userId, scope, createdAt])
}

model SavedResource {
  id           String            @id @default(cuid())
  userId       String
  resourceType SavedResourceType
  resourceId   String
  createdAt    DateTime          @default(now())
  User         User              @relation(fields: [userId], references: [id])

  @@unique([userId, resourceType, resourceId])
  @@index([userId, createdAt])
}

model Message {
  id        String   @id @default(cuid())
  reportId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())
  Report    Report   @relation(fields: [reportId], references: [id])
  User      User     @relation(fields: [senderId], references: [id])

  @@index([reportId, createdAt])
}

/// Anonymous support story submitted after case closure.
/// Only approved stories (approved = true) are shown publicly.
/// No identifying information is stored — no name, no case code.
model SupportStory {
  id        String   @id @default(cuid())
  message   String
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([approved, createdAt])
}

/// Generic key-value store for dynamic frontend content (Hero text, FAQs, Contacts, Footer)
model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

enum ReportStatus {
  RECEIVED
  UNDER_REVIEW
  UNDER_INVESTIGATION
  CLOSED
}

enum Role {
  STAFF
  SUPER_ADMIN
  ADMIN
  COUNSELOR
  INVESTIGATOR
  SUSPENDED
}

enum SavedResourceType {
  ARTICLE
  EVENT
}

enum NotificationScope {
  USER
  ADMIN
}

model AuditLog {
  id           String        @id @default(cuid())
  userId       String
  action       AuditAction
  resourceType AuditResource
  resourceId   String
  details      Json?
  createdAt    DateTime      @default(now())
  User         User          @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([resourceType, resourceId])
}

enum AuditAction {
  VIEWED
  UPDATED
  CREATED
  DELETED
  SUSPENDED
  PROMOTED
}

enum AuditResource {
  REPORT
  USER
  SYSTEM
}
